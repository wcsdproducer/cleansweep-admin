rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to all core collections for the admin portal prototyping
    match /serviceProviders/{document=**} {
      allow read, write: if true;
    }
    match /customers/{document=**} {
      allow read, write: if true;
    }
    match /users/{document=**} {
      allow read, write: if true;
    }
    match /zip_codes/{document=**} {
      allow read, write: if true;
    }
    match /provider_coverage/{document=**} {
      allow read, write: if true;
    }
    match /_system_health/{document=**} {
      allow read, write: if true;
    }
    // Global fallback for prototyping - ensures immediate access
    match /{document=**} {
      allow read, write: if true;
    }
  }
}