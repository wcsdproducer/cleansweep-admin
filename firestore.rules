
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development Mode: Allow full read and write access to all collections
    // to unblock development and provide a smooth prototyping experience.
    // This should be restricted with proper security logic before production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
