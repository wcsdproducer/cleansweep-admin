rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grant full read and write access to the specified administrative user
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "QtKTVNyqnjeZNiOaTJB6m0xaAkn2";
    }
    
    // Allow read access for prototyping; restrict writes to authenticated users
    match /customers/{customerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}