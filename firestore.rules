
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grant full read and write access to the specified administrative user
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "QtKTVNyqnjeZNiOaTJB6m0xaAkn2";
    }
    
    // Simplified development rules for customers: Allow anyone to read and any authenticated user to write
    match /customers/{customerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Simplified development rules for user profiles: Allow anyone to read
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Service Providers rules
    match /serviceProviders/{providerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default fallback: allow read for other collections during development
    match /{document=**} {
      allow read: if true;
    }
  }
}
