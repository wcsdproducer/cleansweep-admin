
{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "A CleanSweep customer record",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "loyaltyCredits": { "type": "number" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "externalAuthId": { "type": "string" }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account details and permissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Super Admin", "Developer", "Manager", "Viewer", "Security"] },
        "status": { "type": "string", "enum": ["Online", "Offline", "Away"] },
        "avatar": { "type": "string", "description": "Seed for avatar generation" }
      },
      "required": ["name", "email", "role"]
    },
    "ServiceProvider": {
      "title": "Service Provider",
      "description": "A contractor or cleaning professional",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "category": { "type": "string", "enum": ["Residential", "Commercial", "Deep Clean", "Industrial"] },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Pending"] },
        "rating": { "type": "number" },
        "joinedDate": { "type": "string", "format": "date-time" },
        "service_center": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "radius_miles": { "type": "number" },
        "state": { "type": "string" }
      },
      "required": ["name", "email", "category"]
    },
    "ZipCode": {
      "title": "Zip Code Coverage",
      "description": "Aggregated metrics for a specific ZIP code area",
      "type": "object",
      "properties": {
        "zip": { "type": "string" },
        "active_providers_count": { "type": "number" },
        "last_customer_request_date": { "type": "string", "format": "date-time" },
        "unfilled_leads": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of CleanSweep customers"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Global user profiles"
    },
    "/serviceProviders/{providerId}": {
      "schema": "ServiceProvider",
      "description": "Registered service providers"
    },
    "/zip_codes/{zip}": {
      "schema": "ZipCode",
      "description": "Coverage monitoring per ZIP code"
    }
  }
}
